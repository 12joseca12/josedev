# Copia a `.env.local` en la raíz del repo (Next.js). Valores reales desde Supabase Dashboard.

# Supabase (público en el navegador)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...

# API del foro y chat terminal (Worker en josecoded-api)
# En local, con `pnpm -C josecoded-api dev` suele ser:
NEXT_PUBLIC_JOSECODED_API_URL=http://127.0.0.1:8787

# Opcional: URLs canónicas y sitemap (producción)
NEXT_PUBLIC_SITE_URL=https://tudominio.com

# Opcional: repositorio 3catinfo (botón «Ver código» en /sobre-mi)
# NEXT_PUBLIC_3CATINFO_REPO_URL=https://github.com/tu-usuario/3catinfo

# Live demo usa POST {NEXT_PUBLIC_JOSECODED_API_URL}/demo/android/start → viewer VNC del backend
